  "title": "Updated observation",
  "riskAssessment": "HIGH",
  "entryType": "DAILY",
  "answers": [
    {
      "fieldId": 1,
      "answer": "updated text"
    },
    {
      "fieldId": 2,
      "answer": "false"
    },
    {
      "fieldId": 3,
      "answer": "9999"
    }
  ]
}

> {%
