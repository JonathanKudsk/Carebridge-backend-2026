### 21) Update dosage
PUT {{url}}/dosages/{{dosage_id}}
  "dosage": "1000 mg",
  "active": false
}

> {%
    client.test("Update medication", function () {
        client.assert(response.status === 200, "Failed to update medication: " + response.status);
        client.assert(response.body.dosage === "1000 mg", "Dosage not updated");
        client.assert(response.body.active === false, "active should be false");
        client.assert(response.body.name === "Paracetamol", "name should be unchanged");
    });
%}

### 26) Get medication again to confirm update persisted
GET {{url}}/medication-charts/{{chart_id}}/medications/{{medication_id}}
Authorization: Bearer {{jwt_token}}

> {%
    client.test("Confirm medication update persisted", function () {
        client.assert(response.status === 200, "Failed to get medication: " + response.status);
        client.assert(response.body.dosage === "1000 mg", "Dosage not persisted");
        client.assert(response.body.active === false, "active not persisted");
    });
%}

