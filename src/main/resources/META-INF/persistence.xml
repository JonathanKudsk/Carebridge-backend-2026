<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="carebridge-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.carebridge.entities.User</class>
        <class>com.carebridge.entities.Event</class>
        <class>com.carebridge.entities.EventType</class>
        <class>com.carebridge.entities.Shift</class>
        <class>com.carebridge.entities.JournalEntry</class>
        <class>com.carebridge.entities.Journal</class>
        <class>com.carebridge.entities.Resident</class>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
        </properties>
    </persistence-unit>
</persistence>